# ============================================================
# ENVIRONMENT CONFIGURATIE
# ============================================================
# Kopieer dit bestand naar .env en pas de waarden aan
# ============================================================

# Domein configuratie (voor SSL)
# Vul hier je domeinnaam in als je die hebt
# DOMAIN=formatie.jouwdomein.nl

# Of gebruik het IP adres van de server
DOMAIN=

# Poorten
# LET OP: Poort 8080 is al in gebruik door andere containers!
# Gebruik poort 8081 voor De Formatie
HTTP_PORT=8081

# HTTPS poort (443) - wordt gebruikt als je SSL hebt
HTTPS_PORT=443

# Email voor Let's Encrypt certificaat verlenging (alleen nodig met domein)
LETSENCRYPT_EMAIL=your-email@example.com

# App configuratie
APP_NAME=De Formatie
APP_ENV=production

# Supabase (optioneel - overschrijft config.js als gezet)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
