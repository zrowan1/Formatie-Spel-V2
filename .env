# ============================================================
# ENVIRONMENT CONFIGURATIE - De Formatie
# ============================================================

# Domein configuratie
# Vul hier je domeinnaam in als je die later krijgt
# DOMAIN=formatie.jouwdomein.nl
DOMAIN=

# Poorten
# Poort 8080 is bezet door freqtrade
# Poort 8081 is beschikbaar voor De Formatie
HTTP_PORT=8081

# HTTPS poort (TEMP - voor testen op poort 443)
HTTPS_PORT=443

# Email voor Let's Encrypt (alleen met domein)
LETSENCRYPT_EMAIL=

# App configuratie
APP_NAME=De Formatie
APP_ENV=production
